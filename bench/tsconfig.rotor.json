{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "Node",
    "rootDir": "./src",
    "outDir": "./rotor/out/src",
    "typeRoots": ["./node_modules/@rbxts", "./rotor/node_modules/@rbxts"],
    "plugins": [
      {
        "transform": "rbxts-transform-boost",
        "hoist": true,
        "verbose": true
      },
      {
        "transform": "rbxts-transform-luau",
        "strict": true,
        "optimize": 2,
        "verbose": true
      }
    ]
  },
  "include": ["./src/server", "./src/shared/tests", "./src/shared/fns.ts"],
  "rbxts": {
    "includePath": "rotor/out/include",
    "rojo": "rotor/default.project.json"
  }
}
