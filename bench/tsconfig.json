{
    "compilerOptions": {
        "target": "ESNext",
        "module": "commonjs",
        "moduleDetection": "force",
        "moduleResolution": "Node",
        "strict": true,
        "noLib": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "rootDir": "./src",
        "typeRoots": [
            "./node_modules/@rbxts"
        ],
        "types": [
            "types"
        ]
    },
    "exclude": [
        "out",
        "node_modules"
    ]
}
